# Copy to `.env.local` for local dev (Next.js loads it automatically).
# Never commit real keys or RPC URLs with embedded secrets.
#
# Replace every 0x000… placeholder below with your deployed addresses (see Pyth chainlist for entropy).
# Defaults in this repo target Base Sepolia (84532). For Base mainnet, switch RPC and
# addresses to the Pyth chainlist values for 8453.

# --- Browser-exposed (NEXT_PUBLIC_*) ---
NEXT_PUBLIC_ORRA_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
# Entropy trivia: draw three major-arcana boosters (Base / Base Sepolia).
NEXT_PUBLIC_ORRA_TRIVIA_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BASE_RPC_URL=https://sepolia.base.org
# Same as contracts/.env ENTROPY_ADDRESS (Entropy *contract* — not the provider address).
NEXT_PUBLIC_ENTROPY_ADDRESS=0x0000000000000000000000000000000000000000
# Optional: first block after Orra deploy; speeds up reading history log scans
NEXT_PUBLIC_ORRA_DEPLOY_BLOCK=

# --- Supabase (project + JS client) ---
# Dashboard: Settings → API (URL + anon key); Settings → API → service_role (server only, never expose).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server only — bypasses PostgREST RLS; use only in trusted API routes / server actions.
SUPABASE_SERVICE_ROLE_KEY=

# --- Server only: Postgres (game `pg` pool; same database as your Supabase project) ---
# Production / Vercel: set this — durable sessions, runs, leaderboard, and profiles rely on Postgres + RLS.
# Local only: omit both ORRA_DATABASE_URL and DATABASE_URL to use .data/orra-game/*.json (single-machine, not for deploy).
# Supabase: Settings → Database → Connection string (URI). Prefer pooler for serverless (port 6543).
# For raw `psql` migrations, use the direct/session connection host if the pooler rejects DDL.
# ORRA_DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# DATABASE_URL=
# After migrations/005_rls.sql: use a non-superuser runtime role and grant:
#   GRANT orra_app TO your_runtime_user;
# Roles with BYPASSRLS bypass RLS; prefer a normal DB user with GRANT orra_app TO ...

# --- Server only: Pyth ---
PYTH_PRO_TOKEN=

# Set to 1 to emit JSON timing lines (orra_api_timing) for /api/pyth-history and
# /api/pyth-history-snapshot in server logs (also on by default in NODE_ENV=development).
# ORRA_API_TIMING_LOG=1

# --- Server only: interpretation (/api/interpret) — at least one provider key ---
GITHUB_MODELS_TOKEN=
# GITHUB_MODELS_MODEL=
BLUESMINDS_API_KEY=
# BLUESMINDS_BASE_URL=
# BLUESMINDS_CHAT_URL=
# BLUESMINDS_MODEL=
OPENROUTER_API_KEY=
# OPENROUTER_FALLBACK_MODEL=
# OPENROUTER_FALLBACK_MODELS=
# OPENROUTER_HTTP_REFERER=
# OPENROUTER_APP_TITLE=

# --- Server only: /api/interpret abuse controls (production) ---
# Comma-separated origins allowed to call POST /api/interpret (e.g. https://yourdomain.com).
# If unset, Vercel sets VERCEL_URL / VERCEL_BRANCH_URL automatically — those https origins are allowed.
# For local `next start` with NODE_ENV=production, set e.g. ORRA_ALLOWED_ORIGINS=http://localhost:3000
# ORRA_ALLOWED_ORIGINS=
# Emergency escape hatch: allow any Origin (not recommended for production).
# ORRA_INTERPRET_TRUST_ANY_ORIGIN=1

# --- Server only: game / trivia ---
# Game APIs use Supabase Postgres when ORRA_DATABASE_URL or DATABASE_URL is set; otherwise local JSON under .data/orra-game/ (dev convenience).

# --- Production hosting ---
