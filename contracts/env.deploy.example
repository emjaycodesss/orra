# Copy to `contracts/.env` (gitignored from repo root) before deploying.
# Chainlist: https://docs.pyth.network/entropy/chainlist
#
# ENTROPY_ADDRESS — Pyth Entropy v2 *contract* (IEntropyV2). Orra calls requestV2 / getFeeV2 here.
#   Must match the app’s NEXT_PUBLIC_ENTROPY_ADDRESS and on-chain orra.entropy().
#
# ENTROPY_PROVIDER_ADDRESS — *Default provider* from the same chainlist row (fulfiller).
#   Different address from ENTROPY_ADDRESS. Only used when running DeployOrra; not in .env.local.

# --- Base Sepolia (84532) — Pyth Entropy v2 (default for this repo) ---
ENTROPY_ADDRESS=0x41c9e39574F40Ad34c79f1C99B66A45eFB830d4c
ENTROPY_PROVIDER_ADDRESS=0x6CC14824Ea2918f5De5C2f75A9Da968ad4BD6344
BASE_RPC_URL=https://sepolia.base.org

# --- Base mainnet (8453) — swap in if deploying to mainnet ---
# ENTROPY_ADDRESS=0x6E7D74FA7d5c90FEF9F0512987605a6d546181Bb
# ENTROPY_PROVIDER_ADDRESS=0x52DeaA1c84233F7bb8C8A45baeDE41091c616506
# BASE_RPC_URL=https://mainnet.base.org

# Deployer EOA (hex, 0x-prefixed). Never commit this file with a real key.
PRIVATE_KEY=0xYOUR_KEY
